---
import MainLayout from '../layouts/MainLayout.astro';
import LandingHero from '../components/LandingHero-1.astro';
import FeaturedGallery from '../components/FeaturedGallery.astro';
import FeaturedWorkScroll from '../components/FeaturedWorkScroll.astro';
---

<MainLayout>
  <section
    class="relative pt-36 pb-24 overflow-hidden bg-cover bg-center"
    style="background-image: url('/images/software.jpg');"
  >
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/50 to-black/75"></div>

    <div class="relative z-10">
      <div class="container-custom">
        <div class="max-w-3xl">
          <p class="text-sm uppercase tracking-[0.2em] text-white/50 mb-4">
            Performance
          </p>

          <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight">
            Software Optimisation
          </h1>

          <p class="mt-6 text-lg md:text-xl text-white/75 leading-relaxed max-w-2xl">
            Refined software optimisation with a focus on clean power delivery,
            drivability and a balanced overall driving experience.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 border-t border-white/10">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-16 items-start">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-4">Overview</p>
          <h2 class="text-3xl md:text-5xl font-semibold text-white leading-tight max-w-2xl">
            Modern performance software designed for a cleaner and more responsive driving feel.
          </h2>
        </div>

        <div class="space-y-10">
          <div>
            <h3 class="text-2xl font-semibold text-white">What I Offer</h3>
            <p class="mt-3 text-white/65 leading-relaxed">
              Software optimisation tailored to the individual vehicle, with attention to
              performance, drivability and a refined result rather than exaggerated claims.
            </p>
          </div>

          <div>
            <h3 class="text-2xl font-semibold text-white">Stage 1 Focus</h3>
            <p class="mt-3 text-white/65 leading-relaxed">
              The main focus is on well-balanced Stage 1 optimisation for supported vehicles,
              aiming for a noticeable yet clean improvement in the overall driving experience.
            </p>
          </div>

          <div>
            <h3 class="text-2xl font-semibold text-white">Vehicle Lookup</h3>
            <p class="mt-3 text-white/65 leading-relaxed">
              The database below allows you to check supported vehicles and view available
              tuning data as a first overview.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="container-custom">
      <div class="mb-8 max-w-3xl">
        <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-4">
          Database
        </p>

        <h2 class="text-3xl md:text-5xl font-semibold text-white leading-tight">
          Browse Available Tuning Files
        </h2>

        <p class="mt-6 text-white/70 text-lg leading-relaxed max-w-2xl">
          Search for supported vehicles and available optimisation data directly below.
        </p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white p-3 md:p-4 overflow-hidden shadow-2xl">
        <iframe
          src="https://tuning-shop.com/iframe/iframe.php?user=7418"
          width="100%"
          scrolling="no"
          frameborder="0"
          style="border:0; min-height:950px;"
          class="rounded-xl"
        ></iframe>
      </div>

      <div class="mt-6">
        <a
          href="https://tuning-shop.com/iframe/iframe.php?user=7418"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-6 py-3 border border-white/20 rounded-md text-white/80 hover:text-white hover:border-white/50 transition-all duration-300"
        >
          Open Fullscreen
        </a>
      </div>
    </div>
  </section>

  <section
    class="relative py-24 overflow-hidden bg-cover bg-center border-t border-white/10"
    style="background-image: url('/images/DSC00627.JPG');"
  >
    <div class="absolute inset-0 bg-black/70"></div>

    <div class="relative z-10">
      <div class="container-custom">
        <div class="max-w-3xl">
          <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-4">
            Enquiries
          </p>

          <h2 class="text-3xl md:text-5xl font-semibold text-white leading-tight">
            Interested in software optimisation for your vehicle?
          </h2>

          <p class="mt-6 text-white/70 text-lg leading-relaxed max-w-2xl">
            Feel free to get in touch for vehicle-specific enquiries, project ideas or general questions.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/contact"
              class="inline-block px-6 py-3 border border-white/60 rounded-md text-white hover:bg-white hover:text-black transition-all duration-300"
            >
              Contact
            </a>

            <a
              href="https://instagram.com/dimi.shoots"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-6 py-3 border border-white/20 rounded-md text-white/80 hover:text-white hover:border-white/50 transition-all duration-300"
            >
              Instagram
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="https://tuning-shop.com/media/js/iframe-loader.js"></script>
</MainLayout>
