---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout>
  <!-- Hero -->
  <section
    class="relative min-h-[475px] pt-36 pb-24 overflow-hidden bg-cover bg-center"
    style="background-image: url('/images/software.jpg');"
  >
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/50 to-black/75"></div>

    <div class="relative z-10">
      <div class="container-custom">
        <div class="max-w-3xl">
          <p class="text-sm uppercase tracking-[0.2em] text-white/50 mb-4">
            Performance
          </p>

          <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight">
            Software Optimisation
          </h1>

          <p class="mt-6 text-lg md:text-xl text-white/75 leading-relaxed max-w-2xl">
            Refined software optimisation with a focus on clean power delivery,
            drivability and a balanced overall driving experience.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-24 border-t border-white/10">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-16 items-start">
        <!-- Left Side -->
        <div class="lg:sticky lg:top-32">
          <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-4">
            Overview
          </p>

          <h2 class="text-3xl md:text-5xl font-semibold text-white leading-tight max-w-2xl">
            Refined performance software with a focus on balance, drivability and clean power delivery.
          </h2>

          <p class="mt-6 text-white/60 leading-relaxed max-w-xl">
            Each optimisation is considered individually based on the vehicle platform,
            software version and intended use.
          </p>
        </div>

        <!-- Right Side Cards -->
        <div class="grid grid-cols-1 gap-5">
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <p class="text-sm uppercase tracking-[0.18em] text-white/35 mb-4">
              
            </p>

            <h3 class="text-2xl font-semibold text-white">
              What I Offer
            </h3>

            <p class="mt-4 text-white/65 leading-relaxed">
              Software optimisation tailored to the individual vehicle, with attention to
              performance, drivability and a refined result rather than exaggerated claims.
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <p class="text-sm uppercase tracking-[0.18em] text-white/35 mb-4">
              
            </p>

            <h3 class="text-2xl font-semibold text-white">
              Stage 1 Focus
            </h3>

            <p class="mt-4 text-white/65 leading-relaxed">
              The main focus is on well-balanced Stage 1 optimisation for supported vehicles,
              aiming for a noticeable yet clean improvement in the overall driving experience.
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <p class="text-sm uppercase tracking-[0.18em] text-white/35 mb-4">
              
            </p>

            <h3 class="text-2xl font-semibold text-white">
              Vehicle Support
            </h3>

            <p class="mt-4 text-white/65 leading-relaxed">
              Every vehicle platform differs depending on engine, ECU type, software version
              and production year. Compatibility and available optimisation options are verified
              individually for each enquiry.
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <p class="text-sm uppercase tracking-[0.18em] text-white/35 mb-4">
              
            </p>

            <h3 class="text-2xl font-semibold text-white">
              Individual Enquiries
            </h3>

            <p class="mt-4 text-white/65 leading-relaxed">
              Get in touch with your vehicle details to receive a tailored response regarding
              support, expected gains and available solutions.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 border-t border-white/10">
  <div class="container-custom">
    <div class="max-w-4xl rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-8">
      <p class="text-sm uppercase tracking-[0.2em] text-white/35 mb-4">
        Legal Notice
      </p>

      <p class="text-white/60 leading-relaxed">
        Software modifications, ECU calibrations or performance-related changes that are not
        individually approved and officially registered in accordance with applicable road
        regulations may be intended for closed-course or motorsport use only. Responsibility
        for road legality remains with the vehicle owner.
      </p>
    </div>
  </div>
</section>

  <!-- CTA -->
  <section
    class="relative py-24 overflow-hidden bg-cover bg-center border-t border-white/10"
    style="background-image: url('/images/DSC00627.JPG');"
  >
    <div class="absolute inset-0 bg-black/70"></div>

    <div class="relative z-10">
      <div class="container-custom">
        <div class="max-w-3xl">
          <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-4">
            Enquiries
          </p>

          <h2 class="text-3xl md:text-5xl font-semibold text-white leading-tight">
            Interested in software optimisation for your vehicle?
          </h2>

          <p class="mt-6 text-white/70 text-lg leading-relaxed max-w-2xl">
            Feel free to get in touch for vehicle-specific enquiries, project ideas or general questions.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/contact"
              class="inline-block px-6 py-3 border border-white/60 rounded-md text-white hover:bg-white hover:text-black transition-all duration-300"
            >
              Contact
            </a>

            <a
              href="https://instagram.com/dimi.shoots"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-6 py-3 border border-white/20 rounded-md text-white/80 hover:text-white hover:border-white/50 transition-all duration-300"
            >
              Instagram
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>