---
import MainLayout from '../layouts/MainLayout.astro';

const success = Astro.url.searchParams.get("success");
---

<MainLayout>
  <!-- Hero -->
  <section
    class="relative min-h-[475px] pt-36 pb-24 overflow-hidden bg-cover bg-center"
    style="background-image: url('/images/contact-hero.jpg');"
  >
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/60 to-black/80"></div>

    <div class="relative z-10 container-custom">
      <div class="max-w-3xl">
        <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-4">
          Contact
        </p>

        <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight">
          Get in Touch
        </h1>

        <p class="mt-6 text-lg md:text-xl text-white/70 leading-relaxed max-w-2xl">
          For private shoots, event coverage, collaborations or general enquiries,
          feel free to send a message.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-24 border-t border-white/10">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-16 items-start">
        <!-- Left Side -->
        <div class="space-y-10">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-3">
              Enquiries
            </p>

            <h2 class="text-2xl md:text-3xl font-semibold text-white">
              Let’s create something clean and memorable.
            </h2>

            <p class="mt-4 text-white/65 leading-relaxed">
              Whether it is a personal vehicle shoot, event coverage or a creative collaboration,
              I am open to selected projects with a strong visual identity.
            </p>
          </div>

          <div class="space-y-4">
            <div>
              <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-2">
                Email
              </p>

              <a
                href="mailto:info@dimishoots.ch"
                class="text-white/80 hover:text-white transition-colors duration-300"
              >
                info@dimishoots.ch
              </a>
            </div>

            <div>
              <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-2">
                Instagram
              </p>

              <a
                href="https://instagram.com/dimi.shoots"
                target="_blank"
                rel="noopener noreferrer"
                class="text-white/80 hover:text-white transition-colors duration-300"
              >
                @dimi.shoots
              </a>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-8">
          <div
              id="success-message"
              class="hidden mb-6 rounded-xl border border-green-500/30 bg-green-500/10 px-4 py-3 text-green-300"
          >
          The enquiry has been sent successfully. Your request will be answered soon.
        </div>

          <form
            method="POST"
            action="/api/contact"
            class="space-y-6"
          >
            <div>
              <label for="name" class="block text-sm text-white/70 mb-2">
                Name
              </label>

              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Your name"
                class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-white placeholder:text-white/30 outline-none focus:border-white/30 transition-colors duration-300"
              />
            </div>

            <div>
              <label for="email" class="block text-sm text-white/70 mb-2">
                Email
              </label>

              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="your@email.com"
                class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-white placeholder:text-white/30 outline-none focus:border-white/30 transition-colors duration-300"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm text-white/70 mb-2">
                Subject
              </label>

              <input
                id="subject"
                name="subject"
                type="text"
                required
                placeholder="Project enquiry"
                class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-white placeholder:text-white/30 outline-none focus:border-white/30 transition-colors duration-300"
              />
            </div>

            <div>
              <label for="message" class="block text-sm text-white/70 mb-2">
                Message
              </label>

              <textarea
                id="message"
                name="message"
                rows="7"
                required
                placeholder="Tell me a bit about your enquiry..."
                class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-white placeholder:text-white/30 outline-none focus:border-white/30 transition-colors duration-300 resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-block px-6 py-3 border border-white/60 rounded-md text-white hover:bg-white hover:text-black transition-all duration-300"
            >
              Send Enquiry
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
  <script>
  const params = new URLSearchParams(window.location.search);
  const success = params.get("success");

  if (success === "1" || success === "true") {
    document.getElementById("success-message")?.classList.remove("hidden");
  }
</script>
</MainLayout>