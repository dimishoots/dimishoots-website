---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <!-- Hero -->
  <section
    class="relative min-h-[475px] pt-36 pb-24 overflow-hidden bg-cover bg-center"
    style="background-image: url('/images/camera.jpg');"
  >
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/50 to-black/75"></div>

    <div class="relative z-10">
      <div class="container-custom">
        <div class="max-w-3xl">
          <p class="text-sm uppercase tracking-[0.2em] text-white/50 mb-4">
            Automotive
          </p>

          <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight">
            Car Photography
          </h1>

          <p class="mt-6 text-lg md:text-xl text-white/75 leading-relaxed max-w-2xl">
            Selected automotive work with a focus on clean visuals, detail and atmosphere.
            Available for private shoots, events and selected collaborations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Selected Work -->
  <section class="py-24 border-t border-white/10">
    <div class="container-custom">
      <div class="mb-12 max-w-3xl">
        <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-4">
          Selected Work
        </p>

        <h2 class="text-3xl md:text-5xl font-semibold text-white leading-tight">
          A curated look at atmosphere, detail and presence.
        </h2>
      </div>

      <div class="space-y-6">
        <div class="overflow-hidden rounded-2xl bg-white/5 border border-white/10">
          <img
            src="/images/car-10.jpg"
            alt="Automotive photography sample 1"
            class="w-full aspect-[4/3] object-cover transition duration-700 hover:scale-105"
          />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="overflow-hidden rounded-2xl bg-white/5 border border-white/10">
            <img
              src="/images/car-11.jpg"
              alt="Automotive photography sample 2"
              class="w-full aspect-[4/3] object-cover transition duration-700 hover:scale-105"
            />
          </div>

          <div class="overflow-hidden rounded-2xl bg-white/5 border border-white/10">
            <img
              src="/images/car-12.jpg"
              alt="Automotive photography sample 3"
              class="w-full aspect-[4/3] object-cover transition duration-700 hover:scale-105"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-24 border-t border-white/10">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-16 items-start">
        <div class="lg:sticky lg:top-32">
          <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-4">
            Services
          </p>

          <h2 class="text-3xl md:text-5xl font-semibold text-white leading-tight max-w-2xl">
            Personal automotive photography with a refined and modern visual approach.
          </h2>

          <p class="mt-6 text-white/60 leading-relaxed max-w-xl">
            Focused on clean compositions, atmosphere and details that make each vehicle feel personal.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-5">
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <h3 class="text-2xl font-semibold text-white">
              Private Shoots
            </h3>

            <p class="mt-4 text-white/65 leading-relaxed">
              Individual shoots for owners who want their vehicle captured with attention to
              detail, atmosphere and a clean premium aesthetic.
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <h3 class="text-2xl font-semibold text-white">
              Events
            </h3>

            <p class="mt-4 text-white/65 leading-relaxed">
              Available for selected car meets, gatherings and automotive events with a calm,
              cinematic style rather than standard event coverage.
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <h3 class="text-2xl font-semibold text-white">
              Collaborations
            </h3>

            <p class="mt-4 text-white/65 leading-relaxed">
              Open to creative collaborations, brand-related projects and selected automotive
              content work.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section
    class="relative py-24 overflow-hidden bg-cover bg-center border-t border-white/10"
    style="background-image: url('/images/DSC00627.JPG');"
  >
    <div class="absolute inset-0 bg-black/70"></div>

    <div class="relative z-10">
      <div class="container-custom">
        <div class="max-w-3xl">
          <p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-4">
            Enquiries
          </p>

          <h2 class="text-3xl md:text-5xl font-semibold text-white leading-tight">
            Interested in a shoot, event coverage or a collaboration?
          </h2>

          <p class="mt-6 text-white/70 text-lg leading-relaxed max-w-2xl">
            Feel free to get in touch for availability, project ideas or general enquiries.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/contact"
              class="inline-block px-6 py-3 border border-white/60 rounded-md text-white hover:bg-white hover:text-black transition-all duration-300"
            >
              Contact
            </a>

            <a
              href="https://instagram.com/dimi.shoots"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-6 py-3 border border-white/20 rounded-md text-white/80 hover:text-white hover:border-white/50 transition-all duration-300"
            >
              Instagram
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>