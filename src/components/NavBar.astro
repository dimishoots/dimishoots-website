---
import siteConfig from '../../site.config.mjs';

const title = siteConfig.title;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isEnglish = currentPath === '/en' || currentPath.startsWith('/en/');

const menuItems = isEnglish
  ? [
      { name: 'Home', link: '/en' },
      { name: 'Car Photography', link: '/en/car-photography' },
      { name: 'Software Optimisation', link: '/en/software-optimisation' },
      { name: 'Contact', link: '/en/contact' },
    ]
  : [
      { name: 'Home', link: '/' },
      { name: 'Fahrzeugfotografie', link: '/car-photography' },
      { name: 'Software Optimierung', link: '/software-optimisation' },
      { name: 'Kontakt', link: '/contact' },
    ];

const dePath = isEnglish
  ? currentPath.replace(/^\/en/, '') || '/'
  : currentPath;

const enPath = isEnglish
  ? currentPath
  : currentPath === '/'
    ? '/en'
    : `/en${currentPath}`;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400..700&display=swap"
  rel="stylesheet"
/>

<nav
  x-data="{ isOpen: false, scrolled: false }"
  @scroll.window="scrolled = window.scrollY > 50"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-200"
  :class="scrolled ? 'py-3 bg-background/80 backdrop-blur shadow-sm' : 'py-5 bg-transparent shadow-none'"
>
  <div class="container mx-auto flex justify-between items-center">
    <a href={isEnglish ? '/en' : '/'} id="logo" class="text-2xl md:text-4xl font-semibold tracking-tight">
      {title}
    </a>

    <div class="hidden md:flex items-center space-x-8">
      {menuItems.map((item) => (
        <a href={item.link} class="nav-link">
          {item.name}
        </a>
      ))}

      <div class="flex items-center gap-2 pl-2 text-sm">
        <a
          href={dePath}
          class={isEnglish ? 'text-white/45 hover:text-white transition-colors' : 'text-white font-medium'}
        >
          DE
        </a>

        <span class="text-white/25">/</span>

        <a
          href={enPath}
          class={isEnglish ? 'text-white font-medium' : 'text-white/45 hover:text-white transition-colors'}
        >
          EN
        </a>
      </div>
    </div>

    <button
      @click="isOpen = !isOpen"
      class="md:hidden text-white/80 hover:text-white focus:outline-none"
      aria-label="Toggle navigation"
    >
      <svg x-show="!isOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
        />
      </svg>

      <svg x-show="isOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"
        />
      </svg>
    </button>
  </div>

  <div
    x-show="isOpen"
    class="md:hidden absolute top-full left-0 w-full bg-background/95 backdrop-blur border-b border-border"
  >
    <div class="flex flex-col py-4 px-6 space-y-4">
      {menuItems.map((item) => (
        <a href={item.link} class="text-lg" @click="isOpen = false">
          {item.name}
        </a>
      ))}

      <div class="flex items-center gap-3 pt-2 text-sm">
        <a href={dePath} class={isEnglish ? 'text-white/45' : 'text-white font-medium'} @click="isOpen = false">
          DE
        </a>

        <span class="text-white/25">/</span>

        <a href={enPath} class={isEnglish ? 'text-white font-medium' : 'text-white/45'} @click="isOpen = false">
          EN
        </a>
      </div>
    </div>
  </div>
</nav>