---
import siteConfig from '../../site.config.mjs';

const owner = siteConfig.owner;
const base = import.meta.env.BASE_URL;
---

<div class="absolute left-0 right-0 z-0">
	<div class="text-center mb-12 relative z-10">
		<h1 class="text-3xl md:text-5xl lg:text-6xl font-bold leading-tight text-white">
			{owner} Automotive Photography
		</h1>
		<p class="mt-4 text-base md:text-lg text-white/75">Professional photography for vehicles of all kinds.</p>
		<a
			href=`/car-photography`
			class="mt-8 inline-block px-6 py-3 border border-white/60 rounded-md
                      hover:bg-white hover:text-black transition-all duration-300
                      text-sm md:text-base font-medium
                      transform hover:scale-105 active:scale-95 text-white"
		>
			Discover More
		</a>
	</div>
</div>
